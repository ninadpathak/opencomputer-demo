OPENCOMPUTER_API_KEY=osb_...        # app.opencomputer.dev → API Keys
ANTHROPIC_API_KEY=sk-ant-...        # console.anthropic.com → API Keys
GITHUB_TOKEN=ghp_...                # github.com/settings/tokens → repo scope
GITHUB_WEBHOOK_SECRET=...           # any random string; paste the same into GitHub
PORT=3000

# Optional:
USE_SNAPSHOT=0                      # 1 = boot the pre-baked "coder" snapshot
CLAUDE_MODEL=claude-sonnet-4-6      # model Claude Code runs in the sandbox
